{
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "muxity"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_USE_A_STRONG_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "muxity-api",
    "Audience": "muxity-web",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Oidc": {
    "google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID"
    },
    "microsoft": {
      "ClientId": "YOUR_MICROSOFT_CLIENT_ID"
    }
  },
  "Storage": {
    "Provider": "Local",
    "MaxFileSizeBytes": 10737418240,
    "Local": {
      "BasePath": "/var/muxity/storage",
      "BaseUrl": "http://localhost:5200/files"
    },
    "S3": {
      "ServiceUrl": "",
      "BucketName": "muxity",
      "Region": "us-east-1",
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "PresignExpiryMinutes": 60
    }
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "TranscodeQueue": "transcode_jobs"
  },
  "Cors": {
    "WebOrigin": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
