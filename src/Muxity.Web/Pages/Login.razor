@page "/login"
@inject OidcService Oidc
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Sign in — Muxity</PageTitle>

<div class="login-page">
    <div class="login-card">
        <h1>Sign in to Muxity</h1>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">@_error</div>
        }

        <div class="login-providers">
            <button class="btn btn-google" @onclick='() => SignIn("google")' disabled="@_busy">
                <span class="provider-icon">G</span> Sign in with Google
            </button>
            <button class="btn btn-microsoft" @onclick='() => SignIn("microsoft")' disabled="@_busy">
                <span class="provider-icon">M</span> Sign in with Microsoft
            </button>
        </div>
    </div>
</div>

@code {
    private bool _busy;
    private string? _error;

    protected override void OnInitialized()
    {
        if (Auth.IsAuthenticated)
            Nav.NavigateTo("/dashboard", replace: true);
    }

    private async Task SignIn(string provider)
    {
        _busy  = true;
        _error = null;
        try { await Oidc.BeginLoginAsync(provider); }
        catch (Exception ex) { _error = ex.Message; _busy = false; }
    }
}
