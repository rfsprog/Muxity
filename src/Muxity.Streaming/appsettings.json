{
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "muxity"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_USE_A_STRONG_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "muxity-api",
    "Audience": "muxity-web"
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "/var/muxity/storage",
      "BaseUrl": "http://localhost:5200/files"
    },
    "S3": {
      "ServiceUrl": "",
      "BucketName": "muxity",
      "Region": "us-east-1",
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "PresignExpiryMinutes": 60
    }
  },
  "Cdn": {
    "Provider": "Passthrough",
    "CloudFront": {
      "BaseUrl": "",
      "KeyPairId": "",
      "PrivateKeyPath": "",
      "ExpiryMinutes": 60
    },
    "Cloudflare": {
      "BaseUrl": "",
      "SigningSecret": "",
      "ExpiryMinutes": 60
    }
  },
  "RateLimit": {
    "RequestsPerWindow": 300,
    "WindowSeconds": 10
  },
  "Cors": {
    "WebOrigin": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
