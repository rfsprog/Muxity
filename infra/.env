# ── Muxity environment defaults ───────────────────────────────────────────────
# Copy to .env.local and fill in real values; never commit secrets.

# MongoDB
MONGO_INITDB_DATABASE=muxity
MONGO_CONNECTION=mongodb://mongodb:27017

# RabbitMQ
RABBITMQ_DEFAULT_USER=muxity
RABBITMQ_DEFAULT_PASS=changeme
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# JWT
JWT_SECRET=CHANGE_ME_USE_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=muxity-api
JWT_AUDIENCE=muxity-web

# OIDC
OIDC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
OIDC_MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID

# Storage  (Local | S3)
STORAGE_PROVIDER=Local
STORAGE_LOCAL_BASE=/var/muxity/storage
STORAGE_LOCAL_BASEURL=http://localhost:5200/files
S3_SERVICE_URL=
S3_BUCKET=muxity
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# CDN  (Passthrough | CloudFront | Cloudflare)
CDN_PROVIDER=Passthrough
CLOUDFRONT_BASE_URL=
CLOUDFRONT_KEYPAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=
CLOUDFLARE_BASE_URL=
CLOUDFLARE_SIGNING_SECRET=

# Transcoder
TRANSCODER_HW_ACCEL=Auto
TRANSCODER_MAX_PARALLEL=2

# Ports (host)
API_PORT=5100
STREAMING_PORT=5200
WEB_PORT=5173
